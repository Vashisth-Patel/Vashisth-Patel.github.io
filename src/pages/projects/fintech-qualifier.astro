---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FintechForm from '../../components/FintechForm.astro';
import QualificationResults from '../../components/QualificationResults.astro';
import ArchitectureCarousel from '../../components/ArchitectureCarousel.astro';
---

<Layout title="AI FinTech Partner Qualifier | Vashisth Patel">
  <Navbar />

  <main class="min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 md:pt-20 pb-8 md:pb-12">
      <!-- Hero Section -->
      <section class="text-center mb-10 md:mb-16">
        <p class="font-mono text-green text-xs uppercase tracking-[0.2em] mb-4">// project showcase</p>

        <h1 class="text-2xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight leading-tight mb-5 max-w-4xl mx-auto">
          AI-Powered Partner Qualification Engine for FinTech
        </h1>

        <p class="text-slate-400 text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          Automate B2B partner triage with hybrid AI + compliance logic. Built for German FinTech startups scaling their partnership pipeline.
        </p>
      </section>

      <!-- Divider -->
      <div class="w-16 h-px bg-slate-700 mx-auto mb-10 md:mb-14"></div>

      <!-- App Interface (Form & Results toggle) -->
      <div class="relative mb-10 md:mb-16">
        <FintechForm />
        <QualificationResults />
      </div>
    </div>

    <!-- Deep Dive Section -->
    <div class="w-full relative bg-navy/80 border-t border-slate-800">
      <div class="absolute inset-0 bg-gradient-to-b from-navy/10 to-transparent pointer-events-none"></div>
      <ArchitectureCarousel />
    </div>
  </main>

  <Footer />
</Layout>
