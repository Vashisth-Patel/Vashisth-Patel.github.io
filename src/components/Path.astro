---
// Path section with real education teaser cards
---

<section id="path" class="max-w-[1000px] mx-auto px-6 sm:px-12 py-24">
  <!-- Section Heading -->
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-3xl font-bold text-lightest-slate font-mono whitespace-nowrap">
      <span class="text-green">03.</span> Academic Background
    </h2>
    <div class="h-[1px] bg-lightest-navy w-full max-w-xs"></div>
  </div>

  <!-- Teaser Cards List -->
  <div class="space-y-6">
    
    <!-- Card 1: EBS University -->
    <div class="group relative bg-light-navy p-6 rounded-lg border border-lightest-navy hover:border-green hover:-translate-y-1 active:scale-[0.98] transition-all duration-300 cursor-pointer" data-modal="education-modal-ebs">
      <!-- Top-right dim link icon -->
      <div class="absolute top-4 right-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-600 group-hover:text-slate-400 transition-colors"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </div>
      <!-- Title -->
      <h3 class="text-xl font-semibold text-lightest-slate mb-2">
        M.Sc. in Management
      </h3>
      
      <!-- Subtitle -->
      <p class="text-slate text-sm mb-1">
        EBS University for Business and Law 
        <a href="https://www.ebs.edu/" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()" class="text-green hover:underline ml-1 text-xs inline-flex items-center gap-0.5">
          ↗ Visit Site
        </a>
      </p>
      <p class="text-green text-xs font-mono mb-4">
        Aug 2024 — July 2026
      </p>
      
      <!-- Metadata Badges -->
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="text-xs font-mono text-green bg-green/10 px-3 py-1 rounded border border-green/30">
          Planned Thesis: SaaS Business Models
        </span>
      </div>
      
      <!-- Bottom Row: Button + Explore Indicator -->
      <div class="flex items-center justify-between mt-2">
        <button class="inline-flex items-center gap-2 px-4 py-2 border border-green text-green font-mono text-sm rounded hover:bg-green/10 transition-colors duration-300">
          View Details &amp; Credentials
          <span class="group-hover:translate-x-1 transition-transform">↗</span>
        </button>
        <span class="text-slate-500 text-xs font-mono flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          Explore <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
        </span>
      </div>
    </div>

    <!-- Card 2: SP Jain -->
    <div class="group relative bg-light-navy p-6 rounded-lg border border-lightest-navy hover:border-green hover:-translate-y-1 active:scale-[0.98] transition-all duration-300 cursor-pointer" data-modal="education-modal-spjain">
      <!-- Top-right dim link icon -->
      <div class="absolute top-4 right-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-600 group-hover:text-slate-400 transition-colors"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </div>
      <!-- Title -->
      <h3 class="text-xl font-semibold text-lightest-slate mb-2">
        Global Management Programme
      </h3>
      
      <!-- Subtitle -->
      <p class="text-slate text-sm mb-1">
        S P Jain Institute of Management and Research
        <a href="https://www.spjimr.org/" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()" class="text-green hover:underline ml-1 text-xs inline-flex items-center gap-0.5">
          ↗ Visit Site
        </a>
      </p>
      <p class="text-green text-xs font-mono mb-4">
        Dec 2023 — June 2024
      </p>
      
      <!-- Metadata Badges -->
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="text-xs font-mono text-green bg-green/10 px-3 py-1 rounded border border-green/30">
          Dean's Honor List - Rank #2
        </span>
        <span class="text-xs font-mono text-green bg-green/10 px-3 py-1 rounded border border-green/30">
          99.7%ile Quant | 99.4%ile DILR
        </span>
      </div>
      
      <!-- Bottom Row: Button + Explore Indicator -->
      <div class="flex items-center justify-between mt-2">
        <button class="inline-flex items-center gap-2 px-4 py-2 border border-green text-green font-mono text-sm rounded hover:bg-green/10 transition-colors duration-300">
          View Details &amp; Credentials
          <span class="group-hover:translate-x-1 transition-transform">↗</span>
        </button>
        <span class="text-slate-500 text-xs font-mono flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          Explore <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
        </span>
      </div>
    </div>

    <!-- Card 3: IIT Gandhinagar -->
    <div class="group relative bg-light-navy p-6 rounded-lg border border-lightest-navy hover:border-green hover:-translate-y-1 active:scale-[0.98] transition-all duration-300 cursor-pointer" data-modal="education-modal-iit">
      <!-- Top-right dim link icon -->
      <div class="absolute top-4 right-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-600 group-hover:text-slate-400 transition-colors"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </div>
      <!-- Title -->
      <h3 class="text-xl font-semibold text-lightest-slate mb-2">
        B.Tech in Materials Science and Engineering
      </h3>
      
      <!-- Subtitle -->
      <p class="text-slate text-sm mb-1">
        Indian Institute of Technology (IIT) Gandhinagar
        <a href="https://iitgn.ac.in/" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()" class="text-green hover:underline ml-1 text-xs inline-flex items-center gap-0.5">
          ↗ Visit Site
        </a>
      </p>
      <p class="text-green text-xs font-mono mb-4">
        Aug 2019 — June 2023
      </p>
      
      <!-- Metadata Badges -->
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="text-xs font-mono text-green bg-green/10 px-3 py-1 rounded border border-green/30">
          JEE Advanced: Rank 7060
        </span>
        <span class="text-xs font-mono text-green bg-green/10 px-3 py-1 rounded border border-green/30">
          JEE Mains: 99.17%ile
        </span>
      </div>
      
      <!-- Bottom Row: Button + Explore Indicator -->
      <div class="flex items-center justify-between mt-2">
        <button class="inline-flex items-center gap-2 px-4 py-2 border border-green text-green font-mono text-sm rounded hover:bg-green/10 transition-colors duration-300">
          View Details &amp; Credentials
          <span class="group-hover:translate-x-1 transition-transform">↗</span>
        </button>
        <span class="text-slate-500 text-xs font-mono flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          Explore <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
        </span>
      </div>
    </div>

  </div>
</section>

<!-- Modal toggle functionality -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('[data-modal]');
    
    cards.forEach(card => {
      card.addEventListener('click', () => {
        const modalId = card.getAttribute('data-modal');
        const modal = document.getElementById(modalId);
        if (modal) {
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          document.body.style.overflow = 'hidden';
        }
      });
    });
  });
</script>
