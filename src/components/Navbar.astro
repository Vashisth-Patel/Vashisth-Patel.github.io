---
// Navbar component with hamburger menu for mobile
---

<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-navy/90 shadow-lg">
  <div class="max-w-[1200px] mx-auto px-6 sm:px-12">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <!-- Logo -->
      <a href="/" class="text-green font-mono text-xl sm:text-2xl font-bold hover:text-green/80 transition-colors">
        VP
      </a>

      <!-- Desktop Navigation Links -->
      <div class="hidden md:flex items-center gap-8">
        <a href="/#about" class="font-mono text-sm text-slate hover:text-green transition-colors">
          <span class="text-green">01.</span> About
        </a>
        <a href="/#experience" class="font-mono text-sm text-slate hover:text-green transition-colors">
          <span class="text-green">02.</span> Professional Impact
        </a>
        <a href="/#path" class="font-mono text-sm text-slate hover:text-green transition-colors">
          <span class="text-green">03.</span> Academic Background
        </a>
        <a href="/#certifications" class="font-mono text-sm text-slate hover:text-green transition-colors">
          <span class="text-green">04.</span> Certifications
        </a>
        <a href="/#contact" class="font-mono text-sm text-slate hover:text-green transition-colors">
          <span class="text-green">05.</span> Contact
        </a>

        <!-- Resume Button -->
        <a
          href="/docs/Vashisth_Patel_CV.pdf"
          target="_blank"
          class="px-4 py-2 border border-green text-green font-mono text-sm rounded hover:bg-green/10 transition-all duration-300"
        >
          Resume
        </a>
      </div>

      <!-- Mobile Hamburger Button -->
      <button
        id="menu-btn"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        class="md:hidden flex flex-col justify-center items-center gap-1.5 w-10 h-10 rounded focus:outline-none focus:ring-2 focus:ring-green/50"
      >
        <span class="block w-6 h-0.5 bg-green transition-all duration-300" id="bar1"></span>
        <span class="block w-6 h-0.5 bg-green transition-all duration-300" id="bar2"></span>
        <span class="block w-6 h-0.5 bg-green transition-all duration-300" id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-navy/95 backdrop-blur-md border-t border-slate-800 overflow-hidden"
  >
    <div class="max-w-[1200px] mx-auto px-6 py-6 flex flex-col gap-5">
      <a href="/#about" class="font-mono text-sm text-slate hover:text-green transition-colors py-1">
        <span class="text-green">01.</span> About
      </a>
      <a href="/#experience" class="font-mono text-sm text-slate hover:text-green transition-colors py-1">
        <span class="text-green">02.</span> Professional Impact
      </a>
      <a href="/#path" class="font-mono text-sm text-slate hover:text-green transition-colors py-1">
        <span class="text-green">03.</span> Academic Background
      </a>
      <a href="/#certifications" class="font-mono text-sm text-slate hover:text-green transition-colors py-1">
        <span class="text-green">04.</span> Certifications
      </a>
      <a href="/#contact" class="font-mono text-sm text-slate hover:text-green transition-colors py-1">
        <span class="text-green">05.</span> Contact
      </a>
      <a
        href="/docs/Vashisth_Patel_CV.pdf"
        target="_blank"
        class="mt-2 inline-block px-4 py-2 border border-green text-green font-mono text-sm rounded hover:bg-green/10 transition-all duration-300 w-fit"
      >
        Resume
      </a>
    </div>
  </div>
</nav>

<!-- Spacer to prevent content from hiding behind fixed navbar -->
<div class="h-16 sm:h-20"></div>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');

    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      menuBtn?.setAttribute('aria-expanded', 'false');
      // Reset bars
      bar1?.classList.remove('rotate-45', 'translate-y-2');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-rotate-45', '-translate-y-2');
    } else {
      mobileMenu?.classList.remove('hidden');
      menuBtn?.setAttribute('aria-expanded', 'true');
      // Animate to X
      bar1?.classList.add('rotate-45', 'translate-y-2');
      bar2?.classList.add('opacity-0');
      bar3?.classList.add('-rotate-45', '-translate-y-2');
    }
  });

  // Close menu when a link is clicked
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      menuBtn?.setAttribute('aria-expanded', 'false');
      bar1?.classList.remove('rotate-45', 'translate-y-2');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-rotate-45', '-translate-y-2');
    });
  });
</script>
