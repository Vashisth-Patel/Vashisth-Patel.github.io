---
// Professional Certifications & Specializations Section
---

<section id="certifications" class="max-w-[1000px] mx-auto px-6 sm:px-12 py-24">
    
    <!-- Section Heading -->
    <div class="flex items-center gap-4 mb-12">
      <h2 class="text-3xl font-bold text-lightest-slate font-mono whitespace-nowrap">
        <span class="text-green">04.</span> Professional Certifications
      </h2>
      <div class="h-[1px] bg-lightest-navy w-full max-w-xs"></div>
    </div>

    <!-- Certifications Grid -->
    <div class="grid md:grid-cols-2 gap-6">
      
      <!-- Management Consulting Specialization (Emory & Coursera) -->
      <a 
        href="/docs/Certificates/Management_Consulting.pdf" 
        target="_blank" 
        rel="noopener noreferrer"
        class="group relative bg-light-navy p-6 rounded-lg border border-lightest-navy hover:border-green hover:-translate-y-1 active:scale-[0.98] transition-all duration-300 flex flex-col"
      >
        <div class="flex items-start justify-between mb-4">
          <div>
            <h3 class="text-xl font-semibold text-lightest-slate mb-2 group-hover:text-green transition-colors">
              Management Consulting Specialization
            </h3>
            <p class="text-green text-sm font-mono mb-3">
              Emory University | Coursera
            </p>
          </div>
          <span class="text-slate-600 group-hover:text-slate-400 transition-colors text-xs mt-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </span>
        </div>
        
        <p class="text-slate text-sm mb-4 leading-relaxed">
          Strategic framework development and client-ready slide creation
        </p>
        
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="px-3 py-1 bg-navy text-green text-xs font-mono rounded border border-green/30">
            Consulting Frameworks
          </span>
          <span class="px-3 py-1 bg-navy text-green text-xs font-mono rounded border border-green/30">
            Problem Solving
          </span>
          <span class="px-3 py-1 bg-navy text-green text-xs font-mono rounded border border-green/30">
            Presentation Skills
          </span>
        </div>

        <div class="flex justify-end mt-auto pt-2">
          <span class="text-slate-500 text-xs font-mono flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            View Certificate <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
          </span>
        </div>
      </a>

      <!-- Harvard Certificate (Opens Modal) -->
      <div
        data-modal="harvard-certifications-modal"
        class="group relative bg-light-navy p-6 rounded-lg border border-lightest-navy hover:border-green hover:-translate-y-1 active:scale-[0.98] transition-all duration-300 cursor-pointer flex flex-col"
      >
        <div class="flex items-start justify-between mb-4">
          <div>
            <h3 class="text-xl font-semibold text-lightest-slate mb-2 group-hover:text-green transition-colors">
              Fundamental Business Certifications
            </h3>
            <p class="text-green text-sm font-mono mb-3">
              Harvard Business Publishing | 6 Certificates
            </p>
          </div>
          <span class="text-slate-600 group-hover:text-slate-400 transition-colors mt-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </span>
        </div>
        
        <p class="text-slate text-sm mb-4 leading-relaxed">
          Comprehensive business fundamentals certification across finance, accounting, and quantitative methods
        </p>
        
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="px-3 py-1 bg-navy text-green text-xs font-mono rounded border border-green/30">
            Finance
          </span>
          <span class="px-3 py-1 bg-navy text-green text-xs font-mono rounded border border-green/30">
            Accounting
          </span>
          <span class="px-3 py-1 bg-navy text-green text-xs font-mono rounded border border-green/30">
            Quantitative Methods
          </span>
        </div>

        <div class="flex justify-end mt-auto pt-2">
          <span class="text-slate-500 text-xs font-mono flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            View Certificates <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
          </span>
        </div>
      </div>

    </div>

    <!-- GDPR Privacy Note -->
    <div class="mt-8 p-4 bg-navy/30 rounded-lg border border-slate/20">
      <p class="text-slate text-xs leading-relaxed">
        <span class="text-green font-semibold">Privacy Note:</span> All certifications are provided as flattened, redacted copies to protect PII. Original unredacted versions are available for verification during the interview process.
      </p>
    </div>
</section>

<!-- Modal Trigger Script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Harvard certifications modal trigger
    const harvardCard = document.querySelector('[data-modal="harvard-certifications-modal"]');
    const modal = document.getElementById('harvard-certifications-modal');
    
    harvardCard?.addEventListener('click', () => {
      modal?.classList.remove('hidden');
      modal?.classList.add('flex');
    });
  });
</script>
